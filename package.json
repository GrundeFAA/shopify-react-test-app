{
  "name": "rt-b2b-app",
  "private": true,
  "scripts": {
    "build": "react-router build && vite build --mode storefront",
    "build:storefront": "vite build --mode storefront",
    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "node ./server.mjs ./build/server/index.js",
    "docker-start": "npm run setup && npm run start",
    "setup": "prisma generate && (prisma migrate deploy || prisma db push)",
    "db:truncate-all": "prisma db execute --file prisma/truncate-all-tables.sql --schema prisma/schema.prisma",
    "db:drop-all": "prisma db execute --file prisma/drop-all-tables.sql --schema prisma/schema.prisma",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@mjackson/node-fetch-server": "^0.7.0",
    "@prisma/client": "6.19",
    "@react-router/dev": "^7.12.0",
    "@react-router/express": "^7.13.1",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.12.0",
    "@trpc/react-query": "^11.12.0",
    "@trpc/server": "^11.12.0",
    "compression": "^1.8.1",
    "isbot": "^5.1.31",
    "morgan": "^1.10.1",
    "prisma": "6.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "source-map-support": "^0.5.21",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.2.1",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@shopify/api-codegen-preset": "^1.2.0",
    "@shopify/dev-mcp": "^1.5.1",
    "@shopify/polaris-types": "^1.0.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "graphql-config": "^5.1.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^6.3.6"
  },
  "workspaces": [
    "extensions/*"
  ],
  "overrides": {
    "p-map": "^4.0.0"
  },
  "author": "GrundeAasen"
}
