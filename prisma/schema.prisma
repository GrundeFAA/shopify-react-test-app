// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

enum AddressType {
  BILLING
  SHIPPING
}

enum MemberRole {
  ADMIN
  USER
}

enum MembershipStatus {
  PENDING
  APPROVED
  DENIED
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

model Company {
  id        String              @id @default(cuid())
  name      String
  orgNumber String?             @unique
  status    CompanyStatus       @default(ACTIVE)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  members   CompanyMember[]
  requests  MembershipRequest[]
  addresses CompanyAddress[]

  @@index([name])
  @@index([orgNumber])
}

// Source of truth for company addresses.
// Synced to Shopify customer addresses for all approved members via CompanyAddressMember.
model CompanyAddress {
  id        String                 @id @default(cuid())
  companyId String
  type      AddressType
  label     String?
  isDefault Boolean                @default(false)
  firstName String?
  lastName  String?
  company   String?
  address1  String
  address2  String?
  city      String
  province  String?
  zip       String
  country   String
  phone     String?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  companyRel Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberMappings CompanyAddressMember[]

  @@index([companyId, type])
}

// Tracks which Shopify MailingAddress ID corresponds to each company address per member.
// Used to update the correct Shopify address on sync, and to avoid touching personal addresses.
model CompanyAddressMember {
  id                String         @id @default(cuid())
  companyAddressId  String
  shopifyCustomerId String
  shopifyAddressId  String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  companyAddress    CompanyAddress @relation(fields: [companyAddressId], references: [id], onDelete: Cascade)

  @@unique([companyAddressId, shopifyCustomerId])
  @@index([shopifyCustomerId])
}

model CompanyMember {
  id                String           @id @default(cuid())
  shop              String
  companyId         String
  shopifyCustomerId String
  role              MemberRole       @default(USER)
  status            MembershipStatus @default(PENDING)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([shop, companyId, shopifyCustomerId])
  @@index([shop, shopifyCustomerId])
  @@index([status])
}

model MembershipRequest {
  id                String           @id @default(cuid())
  shop              String
  companyId         String
  shopifyCustomerId String
  status            MembershipStatus @default(PENDING)
  reason            String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([shop, shopifyCustomerId])
}
